# CodeMentor Agent - 环境变量配置示例
# 复制为 .env 并填入真实值

# ===========================================================================
# LLM Provider 选择
# ===========================================================================
# 可选值：zhipu / ollama / mock
# 留空时按优先级自动检测：ZHIPU_API_KEY > OLLAMA_HOST > mock
LLM_PROVIDER=zhipu

# ===========================================================================
# 智谱 GLM (默认推荐)
# ===========================================================================
# 注册地址：https://bigmodel.cn
# 所有 GLM-4-Flash 系列模型永久免费，无 Token 上限
ZHIPU_API_KEY=

# 模型选择（可选，默认 glm-4-flash）
# 可选值：
#   glm-4-flash                - 基础免费模型，适合日常对话和教学（推荐）
#   glm-4-6v-flash             - 多模态模型，理解图表和图片内容
#   glm-4-7-flash              - 7B 参数模型，平衡性能与速度
#   glm-4-1v-thinking-flash    - 支持思考链，适合逻辑推理任务
#   glm-4v-flash               - 视觉理解模型，分析图像内容
# 也可在网站前端运行时动态切换，无需修改此处
ZHIPU_MODEL=glm-4-flash

# ===========================================================================
# Ollama 本地 (备选，完全离线)
# ===========================================================================
# 安装：winget install Ollama.Ollama
# 拉模型：ollama pull qwen2.5:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
